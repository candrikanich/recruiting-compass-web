{
  "name": "recruiting-compass",
  "version": "1.0.0",
  "description": "High school athlete recruiting guide for parents and students",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxi build",
    "preview": "nuxi preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "nuxi typecheck",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "node tests/a11y/axe-test.js",
    "test:a11y:pa11y": "pa11y-ci --config tests/a11y/.pa11yci.json",
    "db:seed:test": "tsx tests/e2e/seed/seed.ts",
    "db:reset:test": "tsx tests/e2e/seed/reset.ts",
    "analyze": "nuxi build --analyze",
    "build:check": "npm run build && npm run analyze",
    "autofix": "bash scripts/autofix.sh",
    "autofix:security": "bash scripts/autofix.sh --only-security",
    "autofix:lint": "bash scripts/autofix.sh --only-lint",
    "autofix:ci": "bash scripts/autofix.sh --only-ci",
    "ci:heal": "bash scripts/ci-heal.sh",
    "ci:heal:watch": "bash scripts/ci-heal.sh --watch",
    "feature": "bash scripts/feature-tdd.sh --scope web",
    "feature:ios": "bash scripts/feature-tdd.sh --scope ios",
    "feature:both": "bash scripts/feature-tdd.sh --scope both",
    "feature:full": "bash scripts/full-stack-feature.sh",
    "feature:full:web-only": "bash scripts/full-stack-feature.sh --web-only",
    "audit:tokens": "node scripts/token-audit.mjs",
    "audit:tokens:ci": "node scripts/token-audit.mjs --errors-only"
  },
  "dependencies": {
    "@nuxt/ui": "^3.3.7",
    "@nuxtjs/supabase": "^2.0.9",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.53.1",
    "@supabase/supabase-js": "^2.104.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^1.3.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.3.0",
    "fuse.js": "^7.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "nuxt": "^3.21.8",
    "pinia": "^3.0.4",
    "posthog-js": "^1.376.0",
    "resend": "^6.12.3",
    "sanitize-html": "^2.17.5",
    "sortablejs": "^1.15.6",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@iconify-json/heroicons": "^1.2.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/dompurify": "^3.2.0",
    "@types/jspdf": "^1.3.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.4",
    "@types/sanitize-html": "^2.16.1",
    "@types/sortablejs": "^1.15.8",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.0.16",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^20.9.0",
    "pa11y-ci": "^4.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.0.17",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "vite": "^7.3.2",
    "flatted": "^3.4.2",
    "defu": "^6.1.6",
    "reka-ui": "2.8.2",
    "@vercel/nft": "^0.27.4",
    "serialize-javascript": "^7.0.3",
    "basic-ftp": "^5.2.0",
    "dompurify": "^3.4.0",
    "tar": "^7.5.10",
    "svgo": "^4.0.1",
    "rollup": "^4.59.0",
    "minimatch": "^9.0.7",
    "readdir-glob": {
      "minimatch": "^5.1.7"
    },
    "devalue": "^5.6.3",
    "yauzl": "^3.2.1",
    "ajv": "^6.14.0",
    "node-forge": "^1.4.0",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "svix": "^1.92.2",
    "uuid": "^14.0.0",
    "tmp": "^0.2.6",
    "qs": "^6.15.2"
  }
}
